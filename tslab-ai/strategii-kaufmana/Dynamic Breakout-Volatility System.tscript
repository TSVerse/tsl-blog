        <Block Key="buyStop" Category="Formula" Location="280 674" TypeName="DoubleCustomHandlerItem" Width="120" Height="60" ResizablePartWidth="143" ResizablePartHeight="80" OpenParams="true">
          <EditItem Guid="597CC1F3-A0C9-4979-B69E-539482FF04D9" CodeName="buyStop" IsParametersVisible="true" OnlyValueHandlersCanUsed="false" HandlerTypeName="TSLab.ScriptEngine.Template.DoubleCustomHandlerItem+Handler, TSLab.ScriptEngine, Version=3.0.3.1134, Culture=neutral, PublicKeyToken=null">
            <Parameters>
