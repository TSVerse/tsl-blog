            </Parameters>
          </EditItem>
        </Block>
        <Block Key="exitShort" Category="Formula" Location="50 900" TypeName="DoubleCustomHandlerItem" Width="120" Height="60" ResizablePartWidth="143" ResizablePartHeight="80" OpenParams="true">
