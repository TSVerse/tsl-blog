        <Block Key="VarA" Category="Formula" Location="300 100" TypeName="DoubleCustomHandlerItem" Width="120" Height="60" ResizablePartWidth="795.1999999999999" ResizablePartHeight="80" OpenParams="true">
          <EditItem Guid="5908C5F6-081F-4FFF-AFD2-BED16AF2AB71" CodeName="VarA" IsParametersVisible="true" OnlyValueHandlersCanUsed="false" HandlerTypeName="TSLab.ScriptEngine.Template.DoubleCustomHandlerItem+Handler, TSLab.ScriptEngine, Version=3.0.3.1134, Culture=neutral, PublicKeyToken=null">
            <Parameters>
              <Parameter Name="Expression" TypeName="String" Value="i == 0 ? VarA_min_native : Math.Max(VarA_min_native, Math.Min(VarA_max_native, Math.Floor((VarA[-1] * (1 + (Math.Abs(VarA_stdev_native) &gt; 0.000000000001 ? (VarA_stdev_native - VarA_stdev_native[-1]) / VarA_stdev_native : 0))) + 0.5)))" />
              <Parameter Name="StartIndex" TypeName="Int32" Value="250" />
            </Parameters>
          </EditItem>
        </Block>
