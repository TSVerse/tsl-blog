          </EditItem>
        </Block>
        <Block Key="sellStop" Category="Formula" Location="530 674" TypeName="DoubleCustomHandlerItem" Width="120" Height="60" ResizablePartWidth="143" ResizablePartHeight="80" OpenParams="true">
